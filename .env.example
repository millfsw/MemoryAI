# MemoryAI Environment Configuration
# Copy this file to .env and update with your actual values

# Backend Configuration
BACKEND_PORT=8000
DEBUG=false

# Frontend Configuration
FRONTEND_PORT=5173

# PostgreSQL Configuration
POSTGRES_DB=memoryai
POSTGRES_USER=memoryai
POSTGRES_PASSWORD=memoryai_password
POSTGRES_HOST_PORT=5432

# AI API Configuration
# IMPORTANT: Add your actual API key here
AI_API_KEY=your-openai-api-key-here
# For GigaChat or other OpenAI-compatible APIs, change this URL
AI_API_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-3.5-turbo

# JWT Authentication
SECRET_KEY=your-secret-key-change-in-production

# MemoryAI Environment Configuration
# Copy this file to .env and update with your actual values

# Backend Configuration
BACKEND_PORT=8000
DEBUG=false

# Frontend Configuration
FRONTEND_PORT=5173

# PostgreSQL Configuration
POSTGRES_DB=memoryai
POSTGRES_USER=memoryai
POSTGRES_PASSWORD=memoryai_password
POSTGRES_HOST_PORT=5432

# AI API Configuration - Qwen (Recommended)
# Get your API key from: https://dashscope.console.aliyun.com/
AI_API_KEY=your-dashscope-api-key-here
AI_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen3-coder-plus

# Alternative AI configurations (uncomment to use):

# OpenAI (if available in your region):
# AI_API_KEY=your-openai-key-here
# AI_API_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-3.5-turbo

# Groq (free tier available):
# AI_API_KEY=your-groq-key-here
# AI_API_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL=llama-3.1-70b-versatile

# GigaChat (for Russia):
# AI_API_KEY=your-gigachat-key-here
# AI_API_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
# AI_MODEL=GigaChat

# JWT Authentication
SECRET_KEY=your-secret-key-change-in-production
